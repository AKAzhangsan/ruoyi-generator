import request from '@/utils/request'

// 查询{{ functionName }}列表
export function list{{ BusinessName }}(query) {
  return request({
    url: '/{{ moduleName }}/{{ businessName }}/list',
    method: 'get',
    params: query
  })
}

// 查询{{ functionName }}详细
export function get{{ BusinessName }}({{ pkColumn.java_field }}) {
  return request({
    url: '/{{ moduleName }}/{{ businessName }}/' + {{ pkColumn.java_field }},
    method: 'get'
  })
}

// 新增{{ functionName }}
export function add{{ BusinessName }}(data) {
  return request({
    url: '/{{ moduleName }}/{{ businessName }}',
    method: 'post',
    data: data
  })
}

// 修改{{ functionName }}
export function update{{ BusinessName }}(data) {
  return request({
    url: '/{{ moduleName }}/{{ businessName }}',
    method: 'put',
    data: data
  })
}

// 删除{{ functionName }}
export function del{{ BusinessName }}({{ pkColumn.java_field }}) {
  return request({
    url: '/{{ moduleName }}/{{ businessName }}/' + {{ pkColumn.java_field }},
    method: 'delete'
  })
}

// 导出{{ functionName }}
export function export{{ BusinessName }}(query) {
  return request({
    url: '/{{ moduleName }}/{{ businessName }}/export',
    method: 'post',
    params: query,
    responseType: 'blob'
  })
}
