<template>
  <div class="app-container">
    <!-- 搜索栏 -->
    <el-form :model="queryParams" ref="queryRef" :inline="true" v-show="showSearch" label-width="68px">
{% for column in query_columns %}
      <el-form-item label="{{ column.column_comment.split('（')[0].split('(')[0][:4] }}" prop="{{ column.java_field }}">
{% if column.component == 'DatePicker' %}
{% if column.query_type == 'BETWEEN' %}
        <el-date-picker
          v-model="daterange{{ column.cap_java_field }}"
          value-format="{{ column.date_format | default('YYYY-MM-DD') }}"
          type="daterange"
          range-separator="-"
          start-placeholder="开始日期"
          end-placeholder="结束日期"
        ></el-date-picker>
{% else %}
        <el-date-picker
          v-model="queryParams.{{ column.java_field }}"
          placeholder="请选择{{ column.column_comment.split('（')[0].split('(')[0] }}"
          clearable
          value-format="{{ column.date_format | default('YYYY-MM-DD') }}"
          type="date"
        ></el-date-picker>
{% endif %}
{% elif column.component == 'Select' or column.component == 'Radio' %}
        <el-select v-model="queryParams.{{ column.java_field }}" placeholder="请选择{{ column.column_comment.split('（')[0].split('(')[0] }}" clearable>
          <el-option
            v-for="d in {{ column.dict_type }}"
            :key="d.value"
            :label="d.label"
            :value="d.value"
          />
        </el-select>
{% else %}
        <el-input
          v-model="queryParams.{{ column.java_field }}"
          placeholder="请输入{{ column.column_comment.split('（')[0].split('(')[0] }}"
          clearable
          @keyup.enter="handleQuery"
        />
{% endif %}
      </el-form-item>
{% endfor %}
      <el-form-item>
        <el-button type="primary" icon="Search" @click="handleQuery">搜索</el-button>
        <el-button icon="Refresh" @click="resetQuery">重置</el-button>
      </el-form-item>
    </el-form>

    <!-- 操作按钮 -->
    <el-row :gutter="10" class="mb8">
      <el-col :span="1.5">
        <el-button
          type="primary"
          plain
          icon="Plus"
          @click="handleAdd"
          v-hasPermi="['{{ permissionPrefix }}:add']"
        >新增</el-button>
      </el-col>
      <el-col :span="1.5">
        <el-button
          type="success"
          plain
          icon="Edit"
          :disabled="single"
          @click="handleUpdate"
          v-hasPermi="['{{ permissionPrefix }}:edit']"
        >修改</el-button>
      </el-col>
      <el-col :span="1.5">
        <el-button
          type="danger"
          plain
          icon="Delete"
          :disabled="multiple"
          @click="handleDelete"
          v-hasPermi="['{{ permissionPrefix }}:remove']"
        >删除</el-button>
      </el-col>
      <right-toolbar v-model:showSearch="showSearch" @queryTable="getList"></right-toolbar>
    </el-row>

    <!-- 主表列表 -->
    <el-table v-loading="loading" :data="{{ businessName }}List" @selection-change="handleSelectionChange">
      <el-table-column type="selection" width="55" align="center" />
{% for column in list_columns %}
{% if column.is_pk %}
{# 主键列不显示 #}
{% elif column.component == 'Select' or column.component == 'Radio' %}
      <el-table-column label="{{ column.column_comment.split('（')[0].split('(')[0] }}" align="center" prop="{{ column.java_field }}">
        <template #default="scope">
          <dict-tag :options="{{ column.dict_type }}" :value="scope.row.{{ column.java_field }}" />
        </template>
      </el-table-column>
{% elif column.component == 'DatePicker' %}
      <el-table-column label="{{ column.column_comment.split('（')[0].split('(')[0] }}" align="center" prop="{{ column.java_field }}" width="180">
        <template #default="scope">
{% if column.date_format and 'HH' in column.date_format %}
          <span>{% raw %}{{ parseTime(scope.row.{% endraw %}{{ column.java_field }}{% raw %}, '{y}-{m}-{d} {h}:{i}:{s}') }}{% endraw %}</span>
{% else %}
          <span>{% raw %}{{ parseTime(scope.row.{% endraw %}{{ column.java_field }}{% raw %}, '{y}-{m}-{d}') }}{% endraw %}</span>
{% endif %}
        </template>
      </el-table-column>
{% else %}
      <el-table-column label="{{ column.column_comment.split('（')[0].split('(')[0] }}" align="center" prop="{{ column.java_field }}" />
{% endif %}
{% endfor %}
      <el-table-column label="操作" align="center" class-name="small-padding fixed-width">
        <template #default="scope">
          <el-button link type="primary" icon="Edit" @click="handleUpdate(scope.row)" v-hasPermi="['{{ permissionPrefix }}:edit']">修改</el-button>
          <el-button link type="primary" icon="Delete" @click="handleDelete(scope.row)" v-hasPermi="['{{ permissionPrefix }}:remove']">删除</el-button>
        </template>
      </el-table-column>
    </el-table>

    <!-- 分页 -->
    <pagination
      v-show="total > 0"
      :total="total"
      v-model:page="queryParams.pageNum"
      v-model:limit="queryParams.pageSize"
      @pagination="getList"
    />

    <!-- 添加或修改对话框 -->
    <el-dialog :title="title" v-model="open" width="960px" append-to-body>
      <el-form ref="{{ businessName }}Ref" :model="form" :rules="rules" label-width="100px">
{% for column in edit_columns %}
{% if column.column_name not in ['create_by', 'create_time', 'update_by', 'update_time'] %}
        <el-form-item label="{{ column.column_comment.split('（')[0].split('(')[0] }}" prop="{{ column.java_field }}">
{% if column.component == 'DatePicker' %}
          <el-date-picker clearable
            v-model="form.{{ column.java_field }}"
            type="{% if column.date_format and 'HH' in column.date_format %}datetime{% else %}date{% endif %}"
            {% if column.date_format and 'HH' in column.date_format %}
            value-format="YYYY-MM-DD HH:mm:ss"
            {% else %}
            value-format="YYYY-MM-DD"
            {% endif %}
            placeholder="请选择{{ column.column_comment.split('（')[0].split('(')[0] }}">
          </el-date-picker>
{% elif column.component == 'Textarea' %}
          <el-input v-model="form.{{ column.java_field }}" type="textarea" placeholder="请输入{{ column.column_comment.split('（')[0].split('(')[0] }}" />
{% elif column.component == 'Select' %}
          <el-select v-model="form.{{ column.java_field }}" placeholder="请选择{{ column.column_comment.split('（')[0].split('(')[0] }}">
            <el-option
              v-for="d in {{ column.dict_type }}"
              :key="d.value"
              :label="d.label"
              :value="d.value"
            />
          </el-select>
{% elif column.component == 'Radio' %}
          <el-radio-group v-model="form.{{ column.java_field }}">
            <el-radio
              v-for="d in {{ column.dict_type }}"
              :key="d.value"
              :label="d.value"
            >{{ '{{' }} d.label {{ '}}' }}</el-radio>
          </el-radio-group>
{% elif column.component == 'InputNumber' %}
          <el-input-number v-model="form.{{ column.java_field }}" placeholder="请输入{{ column.column_comment.split('（')[0].split('(')[0] }}" />
{% else %}
          <el-input v-model="form.{{ column.java_field }}" placeholder="请输入{{ column.column_comment.split('（')[0].split('(')[0] }}" />
{% endif %}
        </el-form-item>
{% endif %}
{% endfor %}
      </el-form>
      <!-- 子表区域 -->
      <el-divider content-position="center">{{ subTableComment }}信息</el-divider>
      <el-row :gutter="10" class="mb8">
        <el-col :span="1.5">
          <el-button type="primary" icon="Plus" @click="handleAdd{{ subClassName }}">添加</el-button>
        </el-col>
        <el-col :span="1.5">
          <el-button type="danger" icon="Delete" @click="handleDelete{{ subClassName }}">删除</el-button>
        </el-col>
      </el-row>
      <el-table :data="{{ subclassName }}List" :row-class-name="row{{ subClassName }}Index" @selection-change="handle{{ subClassName }}SelectionChange" ref="{{ subclassName }}">
        <el-table-column type="selection" width="50" align="center" />
        <el-table-column label="序号" align="center" prop="index" width="65"/>
{% for column in sub_list_columns %}
{% if column.component == 'InputNumber' %}
        <el-table-column label="{{ column.column_comment.split('（')[0].split('(')[0] }}" prop="{{ column.java_field }}">
          <template #default="scope">
            <el-input-number v-model="scope.row.{{ column.java_field }}" controls-position="right" :min="0" style="width:100%" placeholder="请输入{{ column.column_comment.split('（')[0].split('(')[0] }}" />
          </template>
        </el-table-column>
{% elif (column.component == 'Select' or column.component == 'Radio') and column.dict_type %}
        <el-table-column label="{{ column.column_comment.split('（')[0].split('(')[0] }}" prop="{{ column.java_field }}">
          <template #default="scope">
            <el-select v-model="scope.row.{{ column.java_field }}" style="width:100%" placeholder="请选择{{ column.column_comment.split('（')[0].split('(')[0] }}">
              <el-option
                v-for="dict in {{ column.dict_type }}"
                :key="dict.value"
                :label="dict.label"
                :value="dict.value"
              ></el-option>
            </el-select>
          </template>
        </el-table-column>
{% elif column.component == 'DatePicker' %}
        <el-table-column label="{{ column.column_comment.split('（')[0].split('(')[0] }}" prop="{{ column.java_field }}">
          <template #default="scope">
            <el-date-picker clearable style="width:100%"
              v-model="scope.row.{{ column.java_field }}"
              type="date"
              value-format="YYYY-MM-DD"
              placeholder="请选择{{ column.column_comment.split('（')[0].split('(')[0] }}">
            </el-date-picker>
          </template>
        </el-table-column>
{% else %}
        <el-table-column label="{{ column.column_comment.split('（')[0].split('(')[0] }}" prop="{{ column.java_field }}">
          <template #default="scope">
            <el-input v-model="scope.row.{{ column.java_field }}" placeholder="请输入{{ column.column_comment.split('（')[0].split('(')[0] }}" />
          </template>
        </el-table-column>
{% endif %}
{% endfor %}
      </el-table>
      <template #footer>
        <div class="dialog-footer">
          <el-button type="primary" @click="submitForm">确 定</el-button>
          <el-button @click="cancel">取 消</el-button>
        </div>
      </template>
    </el-dialog>
  </div>
</template>

<script setup name="{{ BusinessName }}">
import { list{{ BusinessName }}, get{{ BusinessName }}, del{{ BusinessName }}, add{{ BusinessName }}, update{{ BusinessName }} } from "@/api/{{ moduleName }}/{{ businessName }}";
{% set all_dict_columns = [] %}
{% for column in list_columns %}
{% if column.dict_type %}
{% if column.dict_type not in all_dict_columns %}
{% set _ = all_dict_columns.append(column.dict_type) %}
{% endif %}
{% endif %}
{% endfor %}
{% for column in sub_list_columns %}
{% if column.dict_type %}
{% if column.dict_type not in all_dict_columns %}
{% set _ = all_dict_columns.append(column.dict_type) %}
{% endif %}
{% endif %}
{% endfor %}

const { proxy } = getCurrentInstance();
{% if all_dict_columns %}
const { {% for dt in all_dict_columns %}{{ dt }}{% if not loop.last %}, {% endif %}{% endfor %} } = proxy.useDict({% for dt in all_dict_columns %}"{{ dt }}"{% if not loop.last %}, {% endif %}{% endfor %});
{% endif %}

const {{ businessName }}List = ref([]);
const {{ subclassName }}List = ref([]);
const open = ref(false);
const loading = ref(true);
const showSearch = ref(true);
const ids = ref([]);
const checked{{ subClassName }} = ref([]);
const single = ref(true);
const multiple = ref(true);
const total = ref(0);
const title = ref("");

{% for column in query_columns %}
{% if column.component == 'DatePicker' and column.query_type == 'BETWEEN' %}
const daterange{{ column.cap_java_field }} = ref([]);
{% endif %}
{% endfor %}

const data = reactive({
  form: {},
  queryParams: {
    pageNum: 1,
    pageSize: 10,
{% for column in query_columns %}
    {{ column.java_field }}: null,
{% endfor %}
  },
  rules: {
{% for column in edit_columns %}
{% if column.is_required %}
    {{ column.java_field }}: [{ required: true, message: "{{ column.column_comment.split('（')[0].split('(')[0] }}不能为空", trigger: "{% if column.component == 'Select' or column.component == 'Radio' or column.component == 'DatePicker' %}change{% else %}blur{% endif %}" }],
{% endif %}
{% endfor %}
  }
});

const { queryParams, form, rules } = toRefs(data);

/** 查询{{ functionName }}列表 */
function getList() {
  loading.value = true;
  queryParams.value.params = {};{% for column in query_columns %}{% if column.component == 'DatePicker' and column.query_type == 'BETWEEN' %}
  if (daterange{{ column.cap_java_field }}.value && daterange{{ column.cap_java_field }}.value.length > 0) {
    queryParams.value.params['begin{{ column.cap_java_field }}'] = daterange{{ column.cap_java_field }}.value[0];
    queryParams.value.params['end{{ column.cap_java_field }}'] = daterange{{ column.cap_java_field }}.value[1];
  }{% endif %}{% endfor %}
  list{{ BusinessName }}(queryParams.value).then(response => {
    {{ businessName }}List.value = response.rows;
    total.value = response.total;
    loading.value = false;
  });
}

// 取消按钮
function cancel() {
  open.value = false;
  reset();
}

// 表单重置
function reset() {
  form.value = {
{% for column in columns %}
    {{ column.java_field }}: null,
{% endfor %}
  };
  {{ subclassName }}List.value = [];
  proxy.resetForm("{{ businessName }}Ref");
}

/** 搜索按钮操作 */
function handleQuery() {
  queryParams.value.pageNum = 1;
  getList();
}

/** 重置按钮操作 */
function resetQuery() {
{% for column in query_columns %}
{% if column.component == 'DatePicker' and column.query_type == 'BETWEEN' %}
  daterange{{ column.cap_java_field }}.value = [];
{% endif %}
{% endfor %}
  proxy.resetForm("queryRef");
  handleQuery();
}

// 多选框选中数据
function handleSelectionChange(selection) {
  ids.value = selection.map(item => item.{{ pkColumn.java_field }});
  single.value = selection.length != 1;
  multiple.value = !selection.length;
}

/** 新增按钮操作 */
function handleAdd() {
  reset();
  open.value = true;
  title.value = "添加{{ functionName }}";
}

/** 修改按钮操作 */
function handleUpdate(row) {
  reset();
  const _{{ pkColumn.java_field }} = row.{{ pkColumn.java_field }} || ids.value;
  get{{ BusinessName }}(_{{ pkColumn.java_field }}).then(response => {
    form.value = response.data;
    {{ subclassName }}List.value = response.data.{{ subclassName }}List;
    open.value = true;
    title.value = "修改{{ functionName }}";
  });
}

/** 提交按钮 */
function submitForm() {
  proxy.$refs["{{ businessName }}Ref"].validate(valid => {
    if (valid) {
      form.value.{{ subclassName }}List = {{ subclassName }}List.value;
      if (form.value.{{ pkColumn.java_field }} != null) {
        update{{ BusinessName }}(form.value).then(response => {
          proxy.$modal.msgSuccess("修改成功");
          open.value = false;
          getList();
        });
      } else {
        add{{ BusinessName }}(form.value).then(response => {
          proxy.$modal.msgSuccess("新增成功");
          open.value = false;
          getList();
        });
      }
    }
  });
}

/** 删除按钮操作 */
function handleDelete(row) {
  const _{{ pkColumn.java_field }}s = row.{{ pkColumn.java_field }} || ids.value;
  proxy.$modal.confirm('是否确认删除{{ functionName }}编号为"' + _{{ pkColumn.java_field }}s + '"的数据项？').then(function() {
    return del{{ BusinessName }}(_{{ pkColumn.java_field }}s);
  }).then(() => {
    getList();
    proxy.$modal.msgSuccess("删除成功");
  }).catch(() => {});
}

/** {{ subTableComment }}序号 */
function row{{ subClassName }}Index({ row, rowIndex }) {
  row.index = rowIndex + 1;
}

/** {{ subTableComment }}添加按钮操作 */
function handleAdd{{ subClassName }}() {
  let obj = {};
{% for column in sub_list_columns %}
  obj.{{ column.java_field }} = "";
{% endfor %}
  {{ subclassName }}List.value.push(obj);
}

/** {{ subTableComment }}删除按钮操作 */
function handleDelete{{ subClassName }}() {
  if (checked{{ subClassName }}.value.length == 0) {
    proxy.$modal.msgError("请先选择要删除的{{ subTableComment }}数据");
  } else {
    const {{ subclassName }}s = {{ subclassName }}List.value;
    const checked{{ subClassName }}s = checked{{ subClassName }}.value;
    {{ subclassName }}List.value = {{ subclassName }}s.filter(function(item) {
      return checked{{ subClassName }}s.indexOf(item.index) == -1;
    });
  }
}

/** 复选框选中数据 */
function handle{{ subClassName }}SelectionChange(selection) {
  checked{{ subClassName }}.value = selection.map(item => item.index);
}

getList();
</script>
